#!/bin/sh
set -eu

# container-host-user
#
# Run a command as the requested runtime UID/GID so bind mounts receive
# host-owned files instead of root-owned files.
#
# Inputs:
# - CHU_UID / CHU_GID: target numeric uid/gid. If either is unset, the script
#   becomes a no-op and execs the command directly.
# - CHU_USER: preferred user name when a new account must be created.
# - CHU_HOME: preferred home directory for the runtime user.
# - CHU_COPY_SKEL: copy missing files from /etc/skel when set to 1.
# - CHU_EXTRA_GIDS: comma- or space-separated supplemental gids.

# Runtime user configuration from the environment.
CHU_UID="${CHU_UID:-}"
CHU_GID="${CHU_GID:-}"
CHU_USER="${CHU_USER:-hostuser}"
CHU_HOME="${CHU_HOME:-}"
CHU_COPY_SKEL="${CHU_COPY_SKEL:-1}"
CHU_EXTRA_GIDS="${CHU_EXTRA_GIDS:-}"

# Print an error and abort execution.
fail() {
  printf '%s\n' "container-host-user: $*" >&2
  exit 1
}

# Test whether a command is available in the current image.
have_command() {
  command -v "$1" >/dev/null 2>&1
}

# Detect util-linux setpriv, not the reduced BusyBox variant.
have_setpriv_reuid() {
  have_command setpriv && setpriv --help 2>&1 | grep -q -- '--reuid'
}

# Find an existing passwd entry by uid and return "name:home".
find_passwd_by_uid() {
  awk -F: -v uid="$1" '$3 == uid { print $1 ":" $6; exit }' /etc/passwd
}

# Find an existing passwd entry by user name and return "uid:home".
find_passwd_by_user() {
  awk -F: -v user="$1" '$1 == user { print $3 ":" $6; exit }' /etc/passwd
}

# Find an existing group name by gid.
find_group_by_gid() {
  awk -F: -v gid="$1" '$3 == gid { print $1; exit }' /etc/group
}

# Find an existing gid by group name.
find_gid_by_group() {
  awk -F: -v group="$1" '$1 == group { print $3; exit }' /etc/group
}

# Remove a conflicting user account when the underlying tooling supports it.
delete_user_if_present() {
  user_name="$1"

  if ! awk -F: -v user="$user_name" '$1 == user { found = 1 } END { exit !found }' /etc/passwd; then
    return 0
  fi

  if have_command deluser; then
    deluser "$user_name" >/dev/null 2>&1 || true
    return 0
  fi

  if have_command userdel; then
    userdel "$user_name" >/dev/null 2>&1 || true
    return 0
  fi

  fail "cannot remove conflicting user $user_name"
}

# Remove a conflicting group when the underlying tooling supports it.
delete_group_if_present() {
  group_name="$1"

  if ! awk -F: -v group="$group_name" '$1 == group { found = 1 } END { exit !found }' /etc/group; then
    return 0
  fi

  if have_command delgroup; then
    delgroup "$group_name" >/dev/null 2>&1 || true
    return 0
  fi

  if have_command groupdel; then
    groupdel "$group_name" >/dev/null 2>&1 || true
    return 0
  fi

  fail "cannot remove conflicting group $group_name"
}

# Create a group using the first supported distro-specific tool.
create_group() {
  group_name="$1"
  gid="$2"

  if have_command groupadd; then
    groupadd -g "$gid" "$group_name" >/dev/null
    return 0
  fi

  if have_command addgroup; then
    addgroup -g "$gid" "$group_name" >/dev/null
    return 0
  fi

  fail "cannot create group $group_name"
}

# Create a user using the first supported distro-specific tool.
create_user() {
  user_name="$1"
  uid="$2"
  group_name="$3"
  home_dir="$4"

  mkdir -p "$home_dir"

  if have_command useradd; then
    useradd -M -u "$uid" -g "$group_name" -d "$home_dir" -s /bin/sh "$user_name" >/dev/null
    return 0
  fi

  if have_command adduser; then
    if adduser --help 2>&1 | grep -q -- 'BusyBox'; then
      adduser -D -H -u "$uid" -G "$group_name" -h "$home_dir" -s /bin/sh "$user_name" >/dev/null
      return 0
    fi

    adduser \
      --disabled-password \
      --gecos "" \
      --uid "$uid" \
      --ingroup "$group_name" \
      --home "$home_dir" \
      --shell /bin/sh \
      "$user_name" >/dev/null
    return 0
  fi

  fail "cannot create user $user_name"
}

# Reuse an existing group for a gid or create a deterministic helper group.
group_name_for_gid() {
  gid="$1"

  existing_group="$(find_group_by_gid "$gid")"
  if [ -n "${existing_group}" ]; then
    printf '%s\n' "${existing_group}"
    return 0
  fi

  candidate="chu-gid-${gid}"
  candidate_gid="$(find_gid_by_group "${candidate}")"
  if [ -n "${candidate_gid}" ] && [ "${candidate_gid}" != "${gid}" ]; then
    candidate="chu-extra-${gid}"
  fi

  create_group "${candidate}" "${gid}"
  printf '%s\n' "${candidate}"
}

# Append the runtime user to an existing supplemental group.
add_user_to_group() {
  user_name="$1"
  group_name="$2"

  if have_command usermod; then
    usermod -aG "$group_name" "$user_name" >/dev/null
    return 0
  fi

  if have_command addgroup; then
    if addgroup --help 2>&1 | grep -q -- 'BusyBox'; then
      addgroup "$user_name" "$group_name" >/dev/null
      return 0
    fi
  fi

  if have_command adduser; then
    adduser "$user_name" "$group_name" >/dev/null
    return 0
  fi

  fail "cannot add user $user_name to group $group_name"
}

# Parse CHU_EXTRA_GIDS and attach the runtime user to each gid.
setup_extra_groups() {
  user_name="$1"
  group_list="$2"

  if [ -z "${group_list}" ]; then
    return 0
  fi

  for gid in $(printf '%s\n' "${group_list}" | tr ',:' '  '); do
    case "${gid}" in
      *[!0-9]* | '')
        fail "CHU_EXTRA_GIDS must be a comma- or space-separated list of numeric gids"
        ;;
    esac

    extra_group="$(group_name_for_gid "${gid}")"
    add_user_to_group "${user_name}" "${extra_group}"
  done
}

# Copy missing skeleton files into the runtime home directory.
copy_skel_if_needed() {
  home_dir="$1"
  uid="$2"
  gid="$3"

  if [ "${CHU_COPY_SKEL}" != "1" ]; then
    return 0
  fi

  if [ ! -d /etc/skel ]; then
    return 0
  fi

  for src in /etc/skel/.[!.]* /etc/skel/..?* /etc/skel/*; do
    if [ ! -e "$src" ]; then
      continue
    fi
    name=$(basename "$src")
    dst="${home_dir}/${name}"
    if [ -e "$dst" ]; then
      continue
    fi
    cp -R "$src" "$dst"
    chown -R "$uid:$gid" "$dst" >/dev/null 2>&1 || true
  done
}

# Drop privileges with the best available backend while preserving groups when
# the backend supports it.
drop_privileges() {
  uid="$1"
  gid="$2"
  user_name="$3"
  shift 3

  if have_command gosu; then
    exec gosu "$uid:$gid" "$@"
  fi

  if have_setpriv_reuid; then
    exec setpriv --reuid "$uid" --regid "$gid" --init-groups "$@"
  fi

  if have_command runuser; then
    exec runuser -u "$user_name" -- "$@"
  fi

  if have_command su; then
    exec su -s /bin/sh "$user_name" -c 'exec "$@"' sh "$@"
  fi

  if have_command su-exec; then
    exec su-exec "$uid:$gid" "$@"
  fi

  fail "no supported privilege-drop backend found"
}

# The script always needs a target command to exec.
if [ "$#" -eq 0 ]; then
  fail "missing command to exec"
fi

# Non-root callers cannot provision users, so they fall through directly.
if [ "$(id -u)" -ne 0 ]; then
  exec "$@"
fi

# Missing uid/gid means "do nothing".
if [ -z "${CHU_UID}" ] || [ -z "${CHU_GID}" ]; then
  exec "$@"
fi

# Reject non-numeric uid/gid input early.
case "${CHU_UID}:${CHU_GID}" in
  *[!0-9:]* | :*)
    fail "CHU_UID and CHU_GID must be numeric"
    ;;
esac

# Derive a default home directory when the caller did not provide one.
if [ -z "${CHU_HOME}" ]; then
  if [ "${CHU_UID}" = "0" ]; then
    CHU_HOME="/root"
  else
    CHU_HOME="/home/${CHU_USER}"
  fi
fi

# Explicit root mapping is a no-op apart from HOME/USER normalization.
if [ "${CHU_UID}" = "0" ] && [ "${CHU_GID}" = "0" ]; then
  export HOME="${CHU_HOME}"
  export USER="root"
  exec "$@"
fi

# Reuse an existing uid when available, otherwise create the requested account.
existing_user_entry="$(find_passwd_by_uid "${CHU_UID}")"
if [ -n "${existing_user_entry}" ]; then
  runtime_user="${existing_user_entry%%:*}"
  runtime_home="${existing_user_entry#*:}"
else
  conflicting_user_entry="$(find_passwd_by_user "${CHU_USER}")"
  if [ -n "${conflicting_user_entry}" ]; then
    conflicting_uid="${conflicting_user_entry%%:*}"
    if [ "${conflicting_uid}" != "${CHU_UID}" ]; then
      delete_user_if_present "${CHU_USER}"
    fi
  fi

  runtime_group="$(find_group_by_gid "${CHU_GID}")"
  if [ -z "${runtime_group}" ]; then
    conflicting_gid="$(find_gid_by_group "${CHU_USER}")"
    if [ -n "${conflicting_gid}" ] && [ "${conflicting_gid}" != "${CHU_GID}" ]; then
      delete_group_if_present "${CHU_USER}"
    fi
    create_group "${CHU_USER}" "${CHU_GID}"
    runtime_group="${CHU_USER}"
  fi

  create_user "${CHU_USER}" "${CHU_UID}" "${runtime_group}" "${CHU_HOME}"
  runtime_user="${CHU_USER}"
  runtime_home="${CHU_HOME}"
fi

# Finalize the runtime environment before dropping privileges.
mkdir -p "${runtime_home}"
chown "${CHU_UID}:${CHU_GID}" "${runtime_home}" >/dev/null 2>&1 || true
copy_skel_if_needed "${runtime_home}" "${CHU_UID}" "${CHU_GID}"
setup_extra_groups "${runtime_user}" "${CHU_EXTRA_GIDS}"

export HOME="${runtime_home}"
export USER="${runtime_user}"
export CHU_USER_SWITCHED=1

drop_privileges "${CHU_UID}" "${CHU_GID}" "${runtime_user}" "$@"
